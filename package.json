{
	"private": true,
	"type": "module",
	"version": "1.5.1",
	"name": "3d-agent",
	"description": "AI-powered 3D model viewer — drag-and-drop glTF/GLB preview tool.",
	"author": "nirholas",
	"license": "Apache-2.0",
	"overrides": {
		"serialize-javascript": ">=7.0.5"
	},
	"engines": {
		"node": "24.x"
	},
	"keywords": [
		"3d-viewer",
		"gltf-viewer",
		"glb-viewer",
		"3d-model-viewer",
		"webgl",
		"threejs",
		"drag-and-drop",
		"3d-agent"
	],
	"workspaces": [
		"agent-payments-sdk",
		"character-studio"
	],
	"main": "src/app.js",
	"browserslist": [
		">1%",
		"not dead"
	],
	"staticFiles": {
		"staticPath": [
			{
				"staticPath": "assets",
				"staticOutDir": "assets"
			}
		]
	},
	"scripts": {
		"postinstall": "npm run build --prefix agent-payments-sdk && node scripts/fix-pump-sdk-esm.mjs",
		"dev": "vite --port 3000",
		"dev:lib": "TARGET=lib vite",
		"build": "vite build",
		"build:animations": "node scripts/build-animations.mjs",
		"build:artifact-viewer": "node scripts/build-artifact-viewer.mjs",
		"build:lib": "TARGET=lib vite build",
		"build:lib:full": "TARGET=lib LIB_FORMATS=es,umd vite build",
		"build:artifact": "vite build --config vite.config.artifact.js",
		"publish:lib": "node scripts/publish-lib.mjs",
		"build:chat": "cd chat && node scripts/ensure-deps.mjs && npm run build && cd .. && mkdir -p dist/chat && cp -rf public/chat/. dist/chat/",
		"build:rider": "mkdir -p dist/rider && cp rider/index.html dist/rider/ && cp -rf rider/assets dist/rider/ && cp -rf rider/build dist/rider/ && cp -rf rider/vendor dist/rider/",
		"build:rider:full": "cd rider && npm ci --prefer-offline --no-audit --no-fund --ignore-engines && npm run build && cd .. && npm run build:rider",
		"build:fast": "npm run build",
		"build:vercel": "npm run build --prefix agent-payments-sdk && NODE_OPTIONS=--max-old-space-size=4096 npm run build && npm run build:lib && npm run build:rider && npm run build:chat && npm run publish:lib",
		"build:all": "npm run build:chat && (npm run build & npm run build:lib & npm run build:rider & wait)",
		"release:lib": "npm run build:lib && npm run publish:lib",
		"clean": "rm -rf dist/* dist-lib/* || true",
		"generate-icons": "node scripts/generate-pwa-icons.mjs",
		"fetch-animations": "node scripts/download-animations.mjs",
		"fetch:mixamo-catalog": "node scripts/fetch-mixamo-catalog.mjs",
		"test": "vitest run",
		"test:pages": "node scripts/test-pages.mjs",
		"test:all": "npm run test && npm run test:pages",
		"verify": "prettier --check . && vite build",
		"format": "prettier --write .",
		"check:dist": "node scripts/check-dist.mjs",
		"deploy": "npm run build:all && npm run check:dist && vercel --local-config vercel.json --prod",
		"postversion": "git push && git push --tags",
		"validate:cards": "node scripts/validate-agent-cards.mjs",
		"db:migrate": "node scripts/apply-migrations.mjs --apply",
		"db:status": "node scripts/apply-migrations.mjs",
		"pump:smoke": "node scripts/pumpfun-lifecycle-smoke.js",
		"pump:refresh-idls": "node scripts/refresh-pump-idls.mjs",
		"seed:skills": "node scripts/seed-skills.js",
		"install:sdk": "npm install --prefix agent-payments-sdk && npm run build --prefix agent-payments-sdk && npm install ./agent-payments-sdk",
		"claude": "./claude.sh"
	},
	"dependencies": {
		"@avaturn/sdk": "^1.1.4",
		"@aws-sdk/client-s3": "latest",
		"@aws-sdk/s3-request-presigner": "latest",
		"@bonfida/spl-name-service": "^3.0.21",
		"@chenglou/pretext": "^0.0.5",
		"@coinbase/x402": "^2.1.0",
		"@coral-xyz/anchor": "^0.31.1",
		"@gltf-transform/core": "^4.3.0",
		"@gltf-transform/extensions": "^4.3.0",
		"@huggingface/inference": "^2.7.0",
		"@jup-ag/api": "^6.0.48",
		"@metaplex-foundation/mpl-core": "^1.10.0",
		"@metaplex-foundation/umi": "^1.5.1",
		"@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
		"@neondatabase/serverless": "^0.10.1",
		"@nirholas/pump-sdk": "^1.0.0",
		"@noble/curves": "^2.2.0",
		"@pump-fun/agent-payments-sdk": "^3.1.0",
		"@pump-fun/pump-sdk": "^1.35.0",
		"@pump-fun/pump-swap-sdk": "^1.15.0",
		"@pythnetwork/hermes-client": "^3.1.0",
		"@sentry/node": "^10.50.0",
		"@solana/actions": "^1.6.6",
		"@solana/kit": "^6.8.0",
		"@solana/pay": "^0.2.0",
		"@solana/spl-token": "^0.4.14",
		"@solana/wallet-adapter-base": "^0.9.23",
		"@solana/wallet-adapter-phantom": "^0.9.24",
		"@solana/wallet-adapter-wallets": "^0.19.32",
		"@solana/web3.js": "latest",
		"@upstash/ratelimit": "^2.0.5",
		"@upstash/redis": "^1.34.3",
		"@x402/core": "^2.11.0",
		"@x402/evm": "^2.11.0",
		"@x402/express": "^2.11.0",
		"@x402/extensions": "^2.11.0",
		"@zauthx402/sdk": "^0.1.14",
		"bcryptjs": "^2.4.3",
		"bn.js": "^5.2.3",
		"bs58": "^6.0.0",
		"dat.gui": "^0.7.9",
		"ethers": "^6.16.0",
		"express": "^4.22.1",
		"gltf-validator": "^2.0.0-dev.3.10",
		"helius-sdk": "^2.2.2",
		"jose": "^5.9.6",
		"livekit-client": "^2.18.8",
		"node-fetch": "^3.3.2",
		"query-string": "^8.1.0",
		"resend": "^6.12.2",
		"sas-lib": "^1.0.10",
		"simple-dropzone": "^0.8.3",
		"three": "latest",
		"vhtml": "^2.2.0",
		"viem": "^2.18.0",
		"ws": "^8.20.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@x402/fetch": "^2.11.0",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"jsdom": "^29.1.0",
		"playwright": "^1.45.1",
		"prettier": "^3.2.5",
		"sharp": "latest",
		"vite": "latest",
		"vite-plugin-pwa": "latest",
		"vitest": "latest",
		"workbox-build": "^7.4.0",
		"workbox-window": "^7.4.0"
	}
}
