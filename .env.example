# ============================================================================
# agent-space — Root Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# This covers both the root server (src/server/) and packages/server.
#
# Quick-start examples:
#
#   Cheapest (Groq LLM + browser TTS):
#     AI_PROVIDER=groq
#     GROQ_API_KEY=gsk_...
#     TTS_PROVIDER=browser
#
#   Best quality (OpenAI Realtime — single key does LLM + STT + TTS):
#     AI_PROVIDER=openai
#     OPENAI_API_KEY=sk-...
#
#   Claude + ElevenLabs voices:
#     AI_PROVIDER=claude
#     ANTHROPIC_API_KEY=sk-ant-...
#     STT_PROVIDER=groq
#     GROQ_API_KEY=gsk_...
#     TTS_PROVIDER=elevenlabs
#     ELEVENLABS_API_KEY=...
#
# ============================================================================

# ── X / Twitter Authentication ──────────────────────────────────────────────
# Required for X Spaces integration. Two options:
#
#   Option A (recommended): Copy auth_token and ct0 cookies from your browser.
#     Open x.com → DevTools → Application → Cookies → copy auth_token & ct0.
#
#   Option B: Username + password login (may trigger 2FA or CAPTCHAs).
#
# If both are set, token-based auth is tried first.

# Option A — cookie-based auth (recommended)
X_AUTH_TOKEN=
X_CT0=

# Option B — credential-based auth
X_USERNAME=
X_PASSWORD=

# Email used during X's verification step (falls back to X_USERNAME if empty)
X_EMAIL=

# ── X Spaces Integration ────────────────────────────────────────────────────

# Set to "true" to enable the X Spaces module (requires auth above).
# X_SPACES_ENABLED=false

# Auto-join this Space URL on startup (optional).
# X_SPACE_URL=

# ── Browser Mode ────────────────────────────────────────────────────────────
# Controls how the agent connects to a browser.
#
# "managed" (default) — Agent launches its own headless Chrome with Puppeteer.
#                       Requires X authentication (tokens, username/password).
#
# "connect" — Agent connects to an already-running Chrome via Chrome DevTools
#             Protocol (CDP). Requires NO authentication since you're already
#             logged in to x.com in that Chrome window. Recommended for development.
#
# To use connect mode:
#   1. Launch Chrome:  google-chrome --remote-debugging-port=9222
#   2. Log into x.com manually in that Chrome
#   3. Set BROWSER_MODE=connect in your .env
#   4. Run the agent (it will auto-discover the CDP endpoint on localhost:9222)

BROWSER_MODE=managed

# ── CDP Connection (for BROWSER_MODE=connect) ────────────────────────────────
# Only needed if BROWSER_MODE=connect. Auto-discovered if omitted.

# Full WebSocket URL for CDP connection. If not set, auto-discovered from host:port.
# Example: ws://localhost:9222/devtools/browser/a1b2c3d4-5678-90ab-cdef-1234567890ab
# CDP_ENDPOINT=

# CDP host for auto-discovery (default: localhost).
# CDP_HOST=localhost

# CDP port for auto-discovery (default: 9222).
# CDP_PORT=9222

# ── AI Provider ─────────────────────────────────────────────────────────────
# Which LLM generates agent responses.
#
# "openai"      — OpenAI Realtime API via WebRTC (~200ms latency, handles its own STT/TTS)
# "openai-chat" — OpenAI Chat Completions, streaming (~800ms, needs separate STT + TTS)
# "claude"      — Anthropic Claude, streaming (~900ms, needs separate STT + TTS)
# "groq"        — Groq with Llama models, streaming (~400ms, needs separate TTS)
AI_PROVIDER=openai

# Override the default model for each provider (optional).
# OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime  # GA model (May 2025). Use gpt-4o-realtime-preview-2024-12-17 to roll back.
# CLAUDE_MODEL=claude-sonnet-4-20250514
# GROQ_MODEL=llama-3.3-70b-versatile

# Model override used by packages/server (optional, provider-specific).
# AI_MODEL=

# Custom system prompt — replaces the built-in agent personality (optional).
# SYSTEM_PROMPT=You are a helpful AI assistant.

# Maximum tokens in AI response (packages/server only, default: 300).
# MAX_TOKENS=300

# ── API Keys ────────────────────────────────────────────────────────────────
# Only the key(s) for your chosen provider(s) are required.

# OpenAI — required for: openai, openai-chat, openai TTS, openai STT
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — required for: claude provider
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq — required for: groq provider, groq STT
# Get your key: https://console.groq.com/
GROQ_API_KEY=

# ElevenLabs — only if TTS_PROVIDER=elevenlabs
# Get your key: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ── Speech-to-Text (STT) ────────────────────────────────────────────────────
# Transcribes user speech to text. Only used with socket-based providers
# (openai-chat, claude, groq). The "openai" realtime provider handles STT internally.
#
# "groq"   — Groq Whisper Large V3 (fast, requires GROQ_API_KEY)
# "openai" — OpenAI Whisper (requires OPENAI_API_KEY)
STT_PROVIDER=groq

# ── Text-to-Speech (TTS) ────────────────────────────────────────────────────
# Converts agent text to spoken audio. Only used with socket-based providers.
#
# "openai"     — OpenAI TTS API (good quality, requires OPENAI_API_KEY)
# "elevenlabs" — ElevenLabs API (best quality, requires ELEVENLABS_API_KEY)
# "browser"    — Browser's built-in speech synthesis (free, lower quality)
#
# Auto-detected if not set: elevenlabs (if key present) > openai (if key present) > browser.
TTS_PROVIDER=openai

# ElevenLabs voice IDs — override defaults per agent (optional).
# Find voices: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_0=VR6AewLTigWG4xSOukaG
# ELEVENLABS_VOICE_1=TxGEqnHWrfWFTfGW9XjX

# ElevenLabs streaming TTS (browser-page mode at /tts/:agentId/stream).
# Activate by loading the agent page with ?tts=elevenlabs (HTTP) or ?tts=elevenlabs-ws (WS).
# Both modes ask the Realtime model for text-only output and synthesize via ElevenLabs.
# The endpoints are gated by ADMIN_API_KEY and rate-limited per-IP (shared token bucket).
#
# HTTP mode  (?tts=elevenlabs):    POST /tts/:id/stream — simple, default.
# WS mode    (?tts=elevenlabs-ws): GET  /tts-ws/:id    — persistent WebSocket to
#   api.elevenlabs.io/v1/text-to-speech/{voice_id}/stream-input; ~100–200 ms lower
#   first-byte latency. Opt-in until proven stable; falls back to HTTP on error.
#   No new env vars — uses the same ELEVENLABS_* settings below.
#
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_OPTIMIZE_LATENCY=2          # 0–4 — higher = faster, lower quality
# ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32  # see https://elevenlabs.io/docs
# ELEVENLABS_MAX_TEXT_CHARS=1500         # per-chunk text cap (cost guardrail; shared by HTTP + WS)
# ELEVENLABS_BURST=8                     # token-bucket burst capacity per IP (shared by HTTP + WS)
# ELEVENLABS_DAILY_CHAR_CAP=200000       # hard daily ceiling (shared counter; resets at UTC midnight)

# Voice ID used by packages/server (optional).
# VOICE_ID=

# ── Security ──────────────────────────────────────────────────────────────────
# These settings secure the admin panel, API, and stored credentials.

# Required: API key for admin panel and Socket.IO authentication.
# Also gates the legacy server.js dashboard at /dashboard, the /alice and /bob
# operator pages, and every privileged endpoint (kick, health, x-tab-url,
# session token minting, prompt updates).
#
# NOTE: ADMIN_API_KEY is the legacy single-key mode. Prefer the operator registry:
#   pnpm operator add <name> [--role admin|viewer]
# When operators.json exists with at least one entry, ADMIN_API_KEY is ignored.
# If neither operators.json nor ADMIN_API_KEY is set, server runs in OPEN dev mode.
# Generate a fallback key with: openssl rand -hex 32
ADMIN_API_KEY=

# Network interface to bind to (default: 127.0.0.1 in open dev mode,
# 0.0.0.0 when ADMIN_API_KEY is set). Override if you need otherwise.
#
# Cloudflare Tunnel: set HOST=127.0.0.1 even when ADMIN_API_KEY is configured.
# Cloudflared connects from localhost, so 0.0.0.0 only exposes port 3000 to the
# VM's network unnecessarily. See docs/deploy-cloudflare-tunnel.md.
# HOST=127.0.0.1

# Public URL of the X Space the agents are broadcasting to. Shown in the
# dashboard top bar; safe to leave blank.
# SPACE_URL=https://x.com/i/spaces/...
# SPACE_TITLE=Friday hangout

# Comma-separated list of allowed CORS origins. Requests from any origin NOT in
# this list are blocked (HTTP 403 / Socket.IO rejected). In production, set this
# to the exact domain(s) that serve the operator UI — wildcard is not accepted.
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Encryption key for cookies stored on disk. If not set, cookies are stored
# in plain text (less secure). Generate with: openssl rand -hex 32
# COOKIE_ENCRYPTION_KEY=

# Rate limiting (per IP). Defaults: 100 requests per 60 seconds.
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# ── Socket Event Rate Limits ─────────────────────────────────────────────────
# Per-operator token-bucket limiter for high-cost Socket.IO events
# (kickRequest, promptUpdate, userMessage, xspace:start, xspace:join).
# Each operator starts with RATE_BURST tokens and refills at RATE_REFILL_PER_SEC.
# Cheap events (kick, userMessage) cost 1 token.
# Expensive events (promptUpdate, xspace:start, xspace:join) cost 3 tokens.
# When the bucket is empty the offending socket receives a "rateLimited" event
# and the dashboard shows a toast. The audit log records every hit.
# RATE_BURST=8
# RATE_REFILL_PER_SEC=1

# ── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3000).
PORT=3000

# Run browser in headless mode (packages/server). Set to "false" to show browser.
# HEADLESS=true

# ── Branding & UI ───────────────────────────────────────────────────────────

# Display name shown in the UI header.
PROJECT_NAME=AI Agents

# Custom avatar image URLs for agents (optional).
# AVATAR_URL_1=
# AVATAR_URL_2=

# Enable text input box in the UI. Set to "false" for voice-only mode.
# INPUT_CHAT=true

# Enable live chat feature. Set to "false" to disable.
# LIVE_CHAT=true

# ── Project / Token Info ────────────────────────────────────────────────────
# Optional metadata displayed in the UI and shared by agents when asked.

# CONTRACT=
# CONTRACT_ADDRESS=
# TOKEN_CHAIN=Solana
# BUY_LINK=
# WEBSITE=
# WEBSITE_LINK=
# TEAM=

# ── Links ───────────────────────────────────────────────────────────────────

# Community / social links shown in the UI.
# X_COMMUNITY_LINK=https://x.com
# X_LINK=https://x.com
# GITHUB_LINK=https://github.com

# ── Watchdog ────────────────────────────────────────────────────────────────
# Background health checker for Chrome CDP ports (runs every WATCHDOG_INTERVAL_MS).
# Emits xTabAlert / xTabRecovered / xTabLoginExpired / xTabHealthSnapshot to dashboards.

# How often (ms) the watchdog polls all CDP ports. Default: 30000 (30 s).
# WATCHDOG_INTERVAL_MS=30000

# CDP debug port for each Chrome instance (override if you use non-default ports).
# CDP_AGENT1_PORT=9222   # Agent 1 WebRTC Chrome (Alice)
# CDP_XTAB1_PORT=9223    # X Space tab for @swarminged
# CDP_AGENT2_PORT=9224   # Agent 2 WebRTC Chrome (Bob)
# CDP_XTAB2_PORT=9225    # X Space tab for @eplus

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Required for paid subscriptions. Get keys at https://dashboard.stripe.com/apikeys

# Stripe secret key (sk_live_... for production, sk_test_... for development)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (from https://dashboard.stripe.com/webhooks)
# Point your webhook to: https://your-domain.com/webhooks/stripe
# Events to enable: checkout.session.completed, customer.subscription.*, invoice.*
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in your Stripe dashboard (recurring, per month)
STRIPE_PRICE_DEVELOPER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_BUSINESS=price_
STRIPE_PRICE_ENTERPRISE=price_

# Stripe Meter IDs — for usage-based billing (session minutes, TTS, STT, LLM)
# STRIPE_METER_SESSION_MINUTES=price_
# STRIPE_METER_TTS_CHARS=price_
# STRIPE_METER_STT_MINUTES=price_
# STRIPE_METER_LLM_TOKENS=price_

# Your app's public URL (used for Stripe redirect URLs)
APP_URL=https://app.xspaceagent.com

# ── GCP / Google Cloud ───────────────────────────────────────────────────────
# Required when deploying to Google Cloud Run / using GCP Secret Manager

# GCP project ID (get from: gcloud config get-value project)
GCP_PROJECT=

# GCP region for Cloud Run + Memorystore (must match infra/terraform/variables.tf)
GCP_REGION=us-central1

# Cloud SQL (PostgreSQL) connection URL — injected automatically by Cloud Run via Secret Manager
# DATABASE_URL=postgresql://xspace:<password>@<private-ip>:5432/xspace?sslmode=require

# Redis URL — Cloud Memorystore (injected via Secret Manager in production)
# REDIS_URL=redis://<host>:6379


